<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

	<targets>
		<!--linux ${basedir}/log/${shortdate}-info.log-->
		<!-- 100 MB-->
		<target xsi:type="File" archiveNumbering="DateAndSequence" archiveAboveSize="100000000" maxArchiveDays="30" archiveFileName="${basedir}\log\archives\${shortdate}-AutotestApi-warn.log" name="target1" fileName="${basedir}\log\${shortdate}-AutotestApi-warn.log">
			<layout xsi:type="JsonLayout">
				<attribute name="time" layout="${date:format=yyyy-MM-dd HH\:mm\:ss.ffffff}" />
				<attribute name="level" layout="${level:uppercase=true}" />
				<attribute name="threadid" layout="${threadid}" />
				<attribute name="methodName" layout="${callsite}" />
				<attribute name="line" layout="${callsite-linenumber}" />
				<attribute name="message" layout="${message}" />
			</layout>
		</target>
		<!--linux ${basedir}/log/${shortdate}-info.log-->
		<target xsi:type="File" archiveNumbering="DateAndSequence" archiveAboveSize="100000000" maxArchiveDays="30" archiveFileName="${basedir}\log\archives\${shortdate}-AutotestApi-info.log" name="target2" fileName="${basedir}\log\${shortdate}-AutotestApi-info.log">
			<layout xsi:type="JsonLayout">
				<attribute name="time" layout="${date:format=yyyy-MM-dd HH\:mm\:ss.ffffff}" />
				<attribute name="level" layout="${level:uppercase=true}" />
				<attribute name="threadid" layout="${threadid}" />
				<attribute name="methodName" layout="${callsite}" />
				<attribute name="line" layout="${callsite-linenumber}" />
				<attribute name="message" layout="${message}" />
			</layout>
		</target>

		<!--linux ${basedir}/log/${shortdate}-debug.log-->
		<target xsi:type="File" archiveNumbering="DateAndSequence" archiveAboveSize="100000000" maxArchiveDays="30" archiveFileName="${basedir}\log\archives\${shortdate}-AutotestApi-debug.log" name="target3" fileName="${basedir}\log\${shortdate}-AutotestApi-debug.log">
			<layout xsi:type="JsonLayout">
				<attribute name="time" layout="${date:format=yyyy-MM-dd HH\:mm\:ss.ffffff}" />
				<attribute name="level" layout="${level:uppercase=true}" />
				<attribute name="threadid" layout="${threadid}" />
				<attribute name="methodName" layout="${callsite}" />
				<attribute name="line" layout="${callsite-linenumber}" />
				<attribute name="message" layout="${message}" />
			</layout>
		</target>



		<!--linux ${basedir}/log/${shortdate}-error.log-->
		<target xsi:type="File" archiveNumbering="DateAndSequence" archiveAboveSize="100000000" maxArchiveDays="30" archiveFileName="${basedir}\log\archives\${shortdate}-AutotestApi-error.log" name="target4" fileName="${basedir}\log\${shortdate}-AutotestApi-error.log">
			<layout xsi:type="JsonLayout">
				<attribute name="time" layout="${date:format=yyyy-MM-dd HH\:mm\:ss.ffffff}" />
				<attribute name="level" layout="${level:uppercase=true}" />
				<attribute name="threadid" layout="${threadid}" />
				<attribute name="methodName" layout="${callsite}" />
				<attribute name="line" layout="${callsite-linenumber}" />
				<attribute name="message" layout="${message}" />
			</layout>
		</target>

		<!--linux ${basedir}/log/${shortdate}-error.log-->
		<target xsi:type="File" archiveNumbering="DateAndSequence" archiveAboveSize="100000000" maxArchiveDays="30" archiveFileName="${basedir}\log\archives\${shortdate}-AutotestApi-LogBatchFile.log" name="target5" fileName="${basedir}\log\${shortdate}-AutotestApi-LogBatchFile.log">
			<layout xsi:type="JsonLayout">
				<attribute name="time" layout="${date:format=yyyy-MM-dd HH\:mm\:ss.ffffff}" />
				<attribute name="level" layout="${level:uppercase=true}" />
				<attribute name="threadid" layout="${threadid}" />
				<attribute name="methodName" layout="${callsite}" />
				<attribute name="line" layout="${callsite-linenumber}" />
				<attribute name="message" layout="${message}" />
			</layout>
		</target>

		<!--linux ${basedir}/log/${shortdate}-infoExpression.log-->
		<target xsi:type="File" archiveNumbering="DateAndSequence" archiveAboveSize="100000000" maxArchiveDays="30" archiveFileName="${basedir}\log\archives\${shortdate}-AutotestApi-DebugExpression.log" name="target6" fileName="${basedir}\log\${shortdate}-AutotestApi-DebugExpression.log">
			<layout xsi:type="JsonLayout">
				<attribute name="time" layout="${date:format=yyyy-MM-dd HH\:mm\:ss.ffffff}" />
				<attribute name="level" layout="${level:uppercase=true}" />
				<attribute name="threadid" layout="${threadid}" />
				<attribute name="methodName" layout="${callsite}" />
				<attribute name="line" layout="${callsite-linenumber}" />
				<attribute name="message" layout="${message}" />
			</layout>
		</target>
		<!--linux ${basedir}/log/${shortdate}-infoExpression.log-->
		<target xsi:type="File" archiveNumbering="DateAndSequence" archiveAboveSize="100000000" maxArchiveDays="30" archiveFileName="${basedir}\log\archives\${shortdate}-AutotestApi-DebugApiRequest.log" name="target7" fileName="${basedir}\log\${shortdate}-AutotestApi-DebugApiRequest.log">
			<layout xsi:type="JsonLayout">
				<attribute name="time" layout="${date:format=yyyy-MM-dd HH\:mm\:ss.ffffff}" />
				<attribute name="level" layout="${level:uppercase=true}" />
				<attribute name="threadid" layout="${threadid}" />
				<attribute name="methodName" layout="${callsite}" />
				<attribute name="line" layout="${callsite-linenumber}" />
				<attribute name="message" layout="${message}" />
			</layout>
		</target>
		

		<target  name="logrequestapi_info_target"  xsi:type="File" archiveNumbering="DateAndSequence" archiveAboveSize="100000000" maxArchiveDays="30" archiveFileName="${basedir}\log\archives\${shortdate}-RequestApi-info.log" fileName="${basedir}\log\${shortdate}-RequestApi-info.log">
			<layout xsi:type="JsonLayout">
				<attribute name="time" layout="${date:format=yyyy-MM-dd HH\:mm\:ss.ffffff}" />
				<attribute name="level" layout="${level:uppercase=true}" />
				<attribute name="threadname" layout="${threadname:whenEmpty=${threadid}}" />
				<attribute name="threadid" layout="${threadid}" />
				<attribute name="methodName" layout="${callsite}" />
				<attribute name="line" layout="${callsite-linenumber}" />
				<attribute name="message" layout="${message}" />
			</layout>
		</target>

		<target  name="logstation_info_target"  xsi:type="File" archiveNumbering="DateAndSequence" archiveAboveSize="100000000" maxArchiveDays="30" archiveFileName="${basedir}\log\archives\${shortdate}-LogStation-info.log" fileName="${basedir}\log\${shortdate}-LogStation-info.log">
			<layout xsi:type="JsonLayout">
				<attribute name="time" layout="${date:format=yyyy-MM-dd HH\:mm\:ss.ffffff}" />
				<attribute name="level" layout="${level:uppercase=true}" />
				<attribute name="threadname" layout="${threadname:whenEmpty=${threadid}}" />
				<attribute name="threadid" layout="${threadid}" />
				<attribute name="methodName" layout="${callsite}" />
				<attribute name="line" layout="${callsite-linenumber}" />
				<attribute name="message" layout="${message}" />
			</layout>
		</target>


		<!--<target xsi:type="File" name="target4" fileName="${basedir}/log/error-${shortdate}.log"
				layout="${longdate} ${level:uppercase=true} ${callsite}:[${callsite-linenumber}] - ${message}"/>-->

		<!--${callsite:className=Boolean:fileName=Boolean:includeSourcePath=Boolean:methodName=Boolean}-->
		<!--${callsite:className=true:methodName:true:fileName=true:includeSourcePath=false} - ${message} ${exception:format=tostring}-->
		<!--${callsite}:line ${callsite-linenumber}-->

	</targets>

	<rules>
		<logger name="logapi" levels="Info" writeTo="logrequestapi_info_target" final="true" />
		<logger name="logstation" levels="Info" writeTo="logstation_info_target" final="true" />
		<logger name="LogBatchFile" levels="Debug" writeTo="target5" final="true" />
		<logger name="DebugExpression" levels="Debug" writeTo="target6" final="true" />
		<logger name="DebugApiRequest" levels="Debug" writeTo="target7" final="true" />
		
		<!--Bỏ qua k ghi những thông tin về hệ thống mặc định-->
		<logger name="Microsoft.*" minlevel="Info" writeTo="" final="true" />
		<logger name="Microsoft.*" minlevel="Debug" writeTo="" final="true" />
		<logger name="Grpc.*" minlevel="Info" writeTo="" final="true" />
		<logger name="Grpc.*" minlevel="Debug" writeTo="" final="true" />

		<logger name="*" levels="Warn" writeTo="target1" final="true" />
		<logger name="*" levels="Info" writeTo="target2" final="true" />
		<logger name="*" levels="Debug" writeTo="target3" final="true" />
		<logger name="*" levels="Error" writeTo="target4" final="true" />

		
 

	</rules>
</nlog>


